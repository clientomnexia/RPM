# RPM Monorepo — Environment Variables
# Set these in your VERCEL dashboard (Environment Variables)

# MongoDB Atlas URI (Production)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/rpm_shop

# JWT Secret for authentication
JWT_SECRET=your_super_strong_secret_key_here

# Environment
NODE_ENV=production

# Note: VITE_API_URL is no longer needed in production
# as we use relative /api paths.

{
    "version": 2,
    "outputDirectory": "dist",
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/admin/:path*",
            "destination": "/admin/index.html"
        },
        {
            "source": "/((?!admin).*)",
            "destination": "/index.html"
        }
    ]
}
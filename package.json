{
    "name": "rpm-monorepo",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "frontend",
        "admin"
    ],
    "scripts": {
        "build": "npm run clean && npm run build:frontend && npm run build:admin",
        "clean": "rm -rf public && mkdir -p public",
        "build:frontend": "cd frontend && npm run build && cp -r dist/* ../public/",
        "build:admin": "cd admin && npm run build && mkdir -p ../public/admin && cp -r dist/admin/* ../public/admin/",
        "dev:backend": "nodemon api/index.js",
        "dev:frontend": "npm run dev --workspace=frontend",
        "dev:admin": "npm run dev --workspace=admin",
        "seed": "node api/seeder.js"
    },
    "dependencies": {
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^16.6.1",
        "express": "^4.22.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^8.23.0",
        "mongoose-unique-validator": "^5.0.2",
        "multer": "^2.1.0"
    },
    "devDependencies": {
        "nodemon": "^3.1.14"
    }
}
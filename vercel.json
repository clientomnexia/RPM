{
    "version": 2,
    "cleanUrls": true,
    "trailingSlash": false,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist"
            }
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/admin/((?!.*\\.).*)",
            "destination": "/admin/index.html"
        },
        {
            "source": "/((?!api|admin|.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}
{
    "version": 2,
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api/index.js"
        },
        {
            "source": "/admin/((?!assets|.*\\.).*)",
            "destination": "/admin/index.html"
        },
        {
            "source": "/((?!api|admin|assets|.*\\.).*)",
            "destination": "/index.html"
        }
    ]
}